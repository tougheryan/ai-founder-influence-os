{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://example.com/content-runtime/audit.schema.json",
  "title": "Pipeline Output: audit",
  "allOf": [
    {
      "$ref": "common.json"
    }
  ],
  "description": "audit 步骤输出文件。body 必须包含以下章节标题：['1. 来源追溯', '2. 事实校验', '5. 修改建议']",
  "properties": {
    "body": {
      "type": "string",
      "minLength": 1,
      "description": "markdown 正文",
      "allOf": [
        {
          "pattern": "(?m)^##\\s*1\\.\\s+来源追溯"
        },
        {
          "pattern": "(?m)^##\\s*2\\.\\s+事实校验"
        },
        {
          "pattern": "(?m)^##\\s*5\\.\\s+修改建议"
        }
      ]
    }
  }
}