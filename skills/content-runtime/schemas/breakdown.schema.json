{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://example.com/content-runtime/breakdown.schema.json",
  "title": "Pipeline Output: breakdown",
  "allOf": [
    {
      "$ref": "common.json"
    }
  ],
  "description": "breakdown 步骤输出文件。body 必须包含以下章节标题：['关键词矩阵', '标题方案', '开场钩子库']",
  "properties": {
    "body": {
      "type": "string",
      "minLength": 1,
      "description": "markdown 正文",
      "allOf": [
        {
          "pattern": "(?m)^##\\s*关键词矩阵"
        },
        {
          "pattern": "(?m)^##\\s*标题方案"
        },
        {
          "pattern": "(?m)^##\\s*开场钩子库"
        }
      ]
    }
  }
}