{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://example.com/content-runtime/angle.schema.json",
  "title": "Pipeline Output: angle",
  "allOf": [
    {
      "$ref": "common.json"
    }
  ],
  "description": "angle 步骤输出文件。body 必须包含以下章节标题：['推荐角度', '角度对比表', '建议']",
  "properties": {
    "body": {
      "type": "string",
      "minLength": 1,
      "description": "markdown 正文",
      "allOf": [
        {
          "pattern": "(?m)^##\\s*推荐角度"
        },
        {
          "pattern": "(?m)^##\\s*角度对比表"
        },
        {
          "pattern": "(?m)^##\\s*建议"
        }
      ]
    }
  }
}