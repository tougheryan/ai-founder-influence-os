{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://example.com/content-runtime/review.schema.json",
  "title": "Pipeline Output: review",
  "allOf": [
    {
      "$ref": "common.json"
    }
  ],
  "description": "review 步骤输出文件。body 必须包含以下章节标题：['1. 表现记录', '3. 评论洞察', '7. 下一条建议']",
  "properties": {
    "body": {
      "type": "string",
      "minLength": 1,
      "description": "markdown 正文",
      "allOf": [
        {
          "pattern": "(?m)^##\\s*1\\.\\s+表现记录"
        },
        {
          "pattern": "(?m)^##\\s*3\\.\\s+评论洞察"
        },
        {
          "pattern": "(?m)^##\\s*7\\.\\s+下一条建议"
        }
      ]
    }
  }
}